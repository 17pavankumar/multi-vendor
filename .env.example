# Copy this file to `.env` and fill in real values. `.env` itself is
# gitignored — never commit real secrets. docker-compose.yml reads
# these into the db/backend/celery containers via env_file/environment.

# --- Database ---------------------------------------------------------
DB_NAME=multivendor
DB_USER=multivendor_app
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me_too

# --- Django -------------------------------------------------------------
DJANGO_SECRET_KEY=replace-with-output-of-get_random_secret_key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Redis / Celery ----------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Razorpay ------------------------------------------------------------
# Test-mode keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Email (deferred feature, placeholder for later phase) -------------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
